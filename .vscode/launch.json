{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run BudAI Extension",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": ["--extensionDevelopmentPath=${workspaceFolder}"],
      "env": {
        "BUDAI_OPEN_ON_ACTIVATION": "1"
      },
      "outFiles": ["${workspaceFolder}/out/**/*.js"],
      "preLaunchTask": "Build BudAI Extension"
    }
  ]
}